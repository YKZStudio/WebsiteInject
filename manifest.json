{
  "manifest_version": 3,
  "name": "WebsiteInject",
  "version": "0.2.0",
  "description": "导入脚本，对指定网站进行注入与修改",
  "permissions": ["userScripts", "storage", "tabs", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebsiteInject",
    "default_icon": "icon.png"
  },
  "options_page": "options.html"
}
